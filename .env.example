# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — two pricing tiers
STRIPE_SECRET_KEY=sk_live_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_ACCOUNTANT_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Anthropic (AI compliance insights — Business + Accountant tiers)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (configured in Supabase Auth → Providers → Google)
# Add the Supabase callback URL to Google Cloud Console authorized redirect URIs.

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Cron (used to authenticate Vercel cron requests)
CRON_SECRET=a-random-secret-string
