# =============================================================================
# OperatorOS — environment variables
# =============================================================================
# Required = app fails to boot or critical paths return 500 / "not configured".
# Optional = feature degrades gracefully (skipped or disabled) when absent.
# =============================================================================

# --- Supabase (REQUIRED) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (REQUIRED for billing) ------------------------------------------
# Three paid tiers: lite ($39), business ($79), accountant ($299). Lite is
# not yet purchasable (see /billing) — its price ID is reserved for when we
# ship the Lite checkout flow. Business + Accountant are required to sell.
#
# Setup (test mode):
#   1. Stripe dashboard → Developers → API keys → use the "Test mode" toggle.
#      Copy the secret key (`sk_test_...`) into STRIPE_SECRET_KEY locally.
#   2. Dashboard → Products → create "OperatorOS Business" ($79/mo recurring)
#      and "OperatorOS Accountant" ($299/mo recurring). Copy each price's
#      ID (`price_...`) into STRIPE_BUSINESS_PRICE_ID / STRIPE_ACCOUNTANT_PRICE_ID.
#   3. Dashboard → Developers → Webhooks → add endpoint at
#      $NEXT_PUBLIC_APP_URL/api/billing/webhook listening for
#      checkout.session.completed, customer.subscription.{created,updated,deleted},
#      invoice.{paid,payment_failed}. Copy the signing secret (`whsec_...`)
#      into STRIPE_WEBHOOK_SECRET.
#   4. For live mode, repeat with the "Live mode" toggle and swap env vars
#      in Vercel production env (test stays in local .env.local).
#
# See docs/billing/SETUP.md for the full checklist including test cards.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_LITE_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_ACCOUNTANT_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (REQUIRED for transactional email) ------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# --- Anthropic (REQUIRED for AI compliance insights + doc expiry extract) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- App (REQUIRED) ---------------------------------------------------------
# Production: your custom domain. Preview: optional — code falls back to VERCEL_URL.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# --- PWA (OPTIONAL — service worker; off until production domain is verified) -
# Set to true only after /api/health shows operatoros-compliance on your domain.
NEXT_PUBLIC_ENABLE_PWA=

# --- Cron (REQUIRED — Vercel cron Bearer token; timing-safe-compared) -------
CRON_SECRET=a-random-secret-string

# --- Google OAuth -----------------------------------------------------------
# Configured in Supabase Auth → Providers → Google. Add the Supabase callback
# URL to Google Cloud Console authorized redirect URIs. No env vars here.

# --- Twilio (OPTIONAL — SMS reminders) --------------------------------------
# Omit all three to disable SMS; sends become silent no-ops in src/lib/sms.ts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- PostHog (OPTIONAL — product analytics) ---------------------------------
# Server-side capture uses POSTHOG_API_KEY (preferred) or NEXT_PUBLIC_POSTHOG_KEY.
# Host defaults to https://us.i.posthog.com when unset.
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=

# --- Intuit / QuickBooks (OPTIONAL — accounting integration) ----------------
# Absent values disable the QuickBooks OAuth flow + sync routes.
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_API_BASE=https://quickbooks.api.intuit.com

# --- Filings providers (OPTIONAL — at least one required for /api/filings) --
# Either Harbor Compliance OR LicenseLogix; if both unset, filings POST returns
# 503 "filings provider not configured".
HARBOR_COMPLIANCE_API_KEY=
LICENSE_LOGIX_API_KEY=
