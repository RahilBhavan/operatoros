# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# claude code
.claude/

# vercel
.vercel

# fleet orchestrator runtime state (per-workstream pid/state/respawn + logs)
/.fleet-state/
/.fleet-logs/

# external design system bundle (referenced read-only; tokens live in src/app/globals.css)
/OperatorOS Design System/

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase CLI local state
/supabase/.temp/
